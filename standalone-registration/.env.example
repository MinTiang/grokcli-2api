# ── Standalone registration service ─────────────────────────────────────────
# Copy to .env and fill in real values.

# Web UI
REG_UI_HOST=0.0.0.0
REG_UI_PORT=8080
REG_UI_PASSWORD=change-me
# Optional fixed bearer for machine API (defaults to random, shown in logs once)
# REG_API_TOKEN=

# Captcha: local (inline turnstile-solver) | yescaptcha
GROK2API_CAPTCHA_PROVIDER=local
GROK2API_LOCAL_SOLVER_URL=http://127.0.0.1:5072
# GROK2API_YESCAPTCHA_KEY=
TURNSTILE_PORT=5072
TURNSTILE_THREAD=3
TURNSTILE_BROWSER_TYPE=camoufox
TURNSTILE_LAZY=1
GROK2API_INLINE_SOLVER=1

# Mail (can also be set fully from the Web UI and persisted to data/config.json)
GROK2API_MAIL_PROVIDER=yyds
GROK2API_YYDS_KEY=
# GROK2API_MOEMAIL_API_KEY=
# GROK2API_MOEMAIL_BASE_URL=https://moemail.example.com
# GROK2API_MOEMAIL_DOMAIN=example.com

# Registration concurrency
GROK2API_REG_CONCURRENCY=3
GROK2API_REG_MAX_CONCURRENCY=10
GROK2API_REG_GLOBAL_INFLIGHT=6

# Force file-mode local auth store (no PostgreSQL required)
GROK2API_STORE_BACKEND=file
GROK2API_DATA_DIR=/app/data

# Optional Redis for durable registration session state across restarts
# REDIS_URL=redis://redis:6379/1

# ── Push target: your central grokcli-2api instance ──────────────────────────
GROKCLI2API_ADMIN_URL=http://your-grokcli2api:3000
GROKCLI2API_ADMIN_TOKEN=
GROKCLI2API_AUTO_PUSH=true
GROKCLI2API_PUSH_SOURCE=standalone-registration

# Skip local pool health probe (standalone has no chat upstream)
GROK2API_REG_SKIP_PROBE=1
